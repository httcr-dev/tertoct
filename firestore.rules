rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function currentRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return currentRole() == 'admin';
    }

    function isCoach() {
      let role = currentRole();
      return role == 'coach' || role == 'admin';
    }

    function canCoachUpdateUser(oldData, newData) {
      // Coaches/admins can update operational fields, but must never elevate roles.
      return newData.diff(oldData).affectedKeys().hasOnly([
        'planId',
        'active',
        'paymentDueDay',
        'monthlyPaymentPaid',
        'paymentValidUntil',
        'bio',
        'photoURL',
        'phone'
      ]);
    }

    function isValidSelfUserCreate(userId, data) {
      return userId == request.auth.uid &&
        data.role == 'student' &&
        (!('active' in data) || data.active == true) &&
        data.keys().hasOnly([
          'name',
          'email',
          'photoURL',
          'role',
          'planId',
          'active',
          'createdAt'
        ]);
    }

    function isPublicCoachProfile(data) {
      return data.role in ['coach', 'admin'] &&
        data.keys().hasOnly(['name', 'photoURL', 'role', 'bio', 'active']);
    }

    function isStudent() {
      let role = currentRole();
      return role == 'student';
    }

    function canReadCheckin(checkinData) {
      return isSignedIn() && (
        checkinData.userId == request.auth.uid ||
        isCoach() ||
        isAdmin()
      );
    }

    function currentUserPlanId() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.planId
        : null;
    }

    function isCurrentUserActive() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        !('active' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }

    function planIsActive(planId) {
      return planId is string &&
        exists(/databases/$(database)/documents/plans/$(planId)) &&
        get(/databases/$(database)/documents/plans/$(planId)).data.active == true;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        userId == request.auth.uid ||
        (isCoach() && resource.data.role == 'student')
      );

      allow create: if isSignedIn() && isValidSelfUserCreate(userId, request.resource.data);

      allow update: if isSignedIn() && (
        (userId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'email', 'photoURL'])) ||
        (isCoach() && canCoachUpdateUser(resource.data, request.resource.data))
      );

      allow delete: if false;
    }

    match /publicProfiles/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && (
        (userId == request.auth.uid && isCoach()) ||
        isAdmin()
      ) && isPublicCoachProfile(request.resource.data);
      allow update: if isSignedIn() && (
        (userId == request.auth.uid && isCoach()) ||
        isAdmin()
      ) && isPublicCoachProfile(request.resource.data) &&
      (!('active' in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if false;
    }

    match /plans/{planId} {
      // Plans are public-facing; allow read for everyone so landing page works
      // without requiring authentication.
      allow read: if true;
      allow create, update, delete: if isCoach();
    }

    match /checkins/{checkinId} {
      allow read: if canReadCheckin(resource.data);

      // Students can only create check-ins for themselves,
      // for their current active plan, and with payment up to date.
      allow create: if isStudent() &&
        isCurrentUserActive() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.planId is string &&
        request.resource.data.weekKey is string &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.planId
          == request.resource.data.planId &&
        get(/databases/$(database)/documents/plans/$(request.resource.data.planId)).data.active
          == true &&
        existsAfter(
          /databases/$(database)/documents/checkinCounters/$(request.auth.uid + '_' + request.resource.data.weekKey)
        ) &&
        getAfter(
          /databases/$(database)/documents/checkinCounters/$(request.auth.uid + '_' + request.resource.data.weekKey)
        ).data.userId == request.auth.uid &&
        getAfter(
          /databases/$(database)/documents/checkinCounters/$(request.auth.uid + '_' + request.resource.data.weekKey)
        ).data.weekKey == request.resource.data.weekKey &&
        getAfter(
          /databases/$(database)/documents/checkinCounters/$(request.auth.uid + '_' + request.resource.data.weekKey)
        ).data.count <= get(/databases/$(database)/documents/plans/$(request.resource.data.planId)).data.classesPerWeek &&
        (
          (
            !exists(/databases/$(database)/documents/checkinCounters/$(request.auth.uid + '_' + request.resource.data.weekKey)) &&
            getAfter(
              /databases/$(database)/documents/checkinCounters/$(request.auth.uid + '_' + request.resource.data.weekKey)
            ).data.count == 1
          ) ||
          (
            exists(/databases/$(database)/documents/checkinCounters/$(request.auth.uid + '_' + request.resource.data.weekKey)) &&
            getAfter(
              /databases/$(database)/documents/checkinCounters/$(request.auth.uid + '_' + request.resource.data.weekKey)
            ).data.count ==
            get(/databases/$(database)/documents/checkinCounters/$(request.auth.uid + '_' + request.resource.data.weekKey)).data.count + 1
          )
        ) &&
        // Payment check: allow if no due day is set, payment is marked as paid, or within valid expiration date
        (
          !('paymentDueDay' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.paymentDueDay == null ||
          (
            'monthlyPaymentPaid' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.monthlyPaymentPaid == true
          ) ||
          (
            'paymentValidUntil' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.paymentValidUntil != null &&
            request.time <= get(/databases/$(database)/documents/users/$(request.auth.uid)).data.paymentValidUntil
          )
        );

      // Check-ins are append-only to manter histórico confiável.
      allow update, delete: if false;
    }

    match /checkinCounters/{counterId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isCoach() ||
        isAdmin()
      );

      allow create, update: if isStudent() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.weekKey is string &&
        counterId == request.auth.uid + '_' + request.resource.data.weekKey &&
        (
          (
            !exists(/databases/$(database)/documents/checkinCounters/$(counterId)) &&
            request.resource.data.count == 1
          ) ||
          (
            exists(/databases/$(database)/documents/checkinCounters/$(counterId)) &&
            request.resource.data.count ==
              get(/databases/$(database)/documents/checkinCounters/$(counterId)).data.count + 1
          )
        );

      allow delete: if false;
    }

    match /feedbacks/{feedbackId} {
      allow read: if true;

      allow create: if isStudent() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() <= 64 &&
        planIsActive(currentUserPlanId()) &&
        isCurrentUserActive();

      allow delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;

      allow update: if false;
    }

    // Future collections (classes, enrollments, payments) can be refined later.
    match /classes/{classId} {
      allow read: if isCoach();
      allow create, update, delete: if isCoach();
    }

    match /enrollments/{id} {
      allow read: if isCoach();
      allow create, update, delete: if isCoach();
    }

    match /payments/{id} {
      allow read, create: if isCoach() || isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}

